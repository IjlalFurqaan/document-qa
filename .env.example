# ─── Google Cloud Configuration ─────────────────────────────────────────────
# Option 1: Use Application Default Credentials (recommended)
#   Run: gcloud auth application-default login
#   Then set your project ID below:
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Option 2: Use a Gemini API key directly
# GOOGLE_API_KEY=your-api-key-here

# ─── Hybrid Search ──────────────────────────────────────────────────────────
# Alpha controls semantic vs keyword weight (0.0 = keyword only, 1.0 = semantic only)
HYBRID_SEARCH_ALPHA=0.7

# ─── Conversation Memory ────────────────────────────────────────────────────
# Number of previous Q&A turns to retain in context
MEMORY_WINDOW_SIZE=5

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
